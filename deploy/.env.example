# =================================================================
# MiniGamer 生产环境配置示例
#
# 部署时：
#   1. 在服务器上：cp .env.example .env
#   2. 把下方所有 "REPLACE_ME_*" 改成真实值
#   3. JWT_SECRET_KEY 用 `openssl rand -hex 32` 生成
#
# ⚠️ 真实的 .env 文件已被 .gitignore，切勿提交！
# =================================================================

# ---------- 应用基础 ----------
APP_ENV=dev
APP_NAME=MiniGamer
APP_HOST=0.0.0.0
APP_PORT=8000
APP_DEBUG=true

# ---------- 数据库（容器内网络，host 用服务名 postgres） ----------
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=minigamer
POSTGRES_PASSWORD=REPLACE_ME_WITH_STRONG_DB_PASSWORD
POSTGRES_DB=minigamer
DATABASE_URL=postgresql+asyncpg://minigamer:REPLACE_ME_WITH_STRONG_DB_PASSWORD@postgres:5432/minigamer

# ---------- Redis ----------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_URL=redis://redis:6379/0

# ---------- JWT（32+ 位随机串，openssl rand -hex 32 生成） ----------
JWT_SECRET_KEY=REPLACE_ME_WITH_openssl_rand_hex_32_RESULT
JWT_ALGORITHM=HS256
JWT_ACCESS_TTL_MINUTES=60
JWT_REFRESH_TTL_DAYS=30

# ---------- 微信小程序（小程序后台 -> 开发管理 -> 开发设置） ----------
WECHAT_APPID=wx_REPLACE_ME
WECHAT_SECRET=REPLACE_ME
WECHAT_API_BASE=https://api.weixin.qq.com

# ---------- AI Provider：支持 qwen / deepseek / openai / mock ----------
AI_PROVIDER=qwen
AI_DEFAULT_MODEL=qwen-plus

OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# 通义千问（DashScope 兼容模式）
QWEN_API_KEY=REPLACE_ME_WITH_YOUR_QWEN_API_KEY
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# ---------- CORS（小程序是 servicewechat.com） ----------
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,https://servicewechat.com,http://81.71.89.228

# ---------- 日志 ----------
LOG_LEVEL=INFO
LOG_FILE=logs/app.log
