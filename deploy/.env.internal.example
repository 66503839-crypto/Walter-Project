# =================================================================
# 内网部署模板（CVM walteryang-any3）
#
# 部署时：cp .env.internal.example /data/minigamer/.env 后填真实值
# 不要提交到 Git（deploy/.env 和 /data/minigamer/.env 都在 gitignore）
# =================================================================

# ---------- 应用 ----------
# prod 下 init_db 仍会自动建表（已在 session.py 去除 dev 限制）
APP_ENV=prod
APP_NAME=MiniGamer-Internal
APP_HOST=0.0.0.0
APP_PORT=8000
APP_DEBUG=false

# ---------- 数据库 ----------
POSTGRES_USER=minigamer
POSTGRES_PASSWORD=REPLACE_ME_STRONG_PASSWORD
POSTGRES_DB=minigamer
# 容器内部用服务名 postgres，compose 会自动解析
DATABASE_URL=postgresql+asyncpg://minigamer:REPLACE_ME_STRONG_PASSWORD@postgres:5432/minigamer

# ---------- Redis ----------
REDIS_URL=redis://redis:6379/0

# ---------- JWT（开机时用 openssl rand -hex 32 生成） ----------
JWT_SECRET_KEY=REPLACE_ME_WITH_openssl_rand_hex_32
JWT_ALGORITHM=HS256
JWT_ACCESS_TTL_MINUTES=60
JWT_REFRESH_TTL_DAYS=30

# ---------- 微信小程序 ----------
WECHAT_APPID=wxba83d0ebfc02609e
WECHAT_SECRET=REPLACE_ME_WITH_WECHAT_SECRET
WECHAT_API_BASE=https://api.weixin.qq.com

# ---------- AI Provider ----------
# 可选值：qwen / tokenplan / deepseek / openai / mock
AI_PROVIDER=tokenplan
AI_DEFAULT_MODEL=tc-code-latest

# 通义千问（DashScope 兼容）
QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# 腾讯云 TokenPlan
TOKENPLAN_API_KEY=REPLACE_ME_WITH_TOKENPLAN_KEY
TOKENPLAN_BASE_URL=https://api.lkeap.cloud.tencent.com/plan/v3
TOKENPLAN_DEFAULT_MODEL=tc-code-latest

# DeepSeek
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# OpenAI
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# ---------- CORS ----------
# servicewechat.com 是小程序真机 origin
# walteryang-any3.devcloud.woa.com 自己访问 docs 时用
CORS_ORIGINS=https://servicewechat.com,https://walteryang-any3.devcloud.woa.com

# ---------- 日志 ----------
LOG_LEVEL=INFO
LOG_FILE=/app/logs/app.log
