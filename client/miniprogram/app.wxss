page {
  background: #f5f6f7;
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', sans-serif;
}

.page {
  padding: 32rpx;
  box-sizing: border-box;
  min-height: 100vh;
}

.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
  margin-bottom: 24rpx;
}

.btn-primary {
  background: #1296db;
  color: #fff;
  border-radius: 12rpx;
  padding: 20rpx;
  text-align: center;
  font-size: 30rpx;
}

.btn-danger {
  background: #e64340;
  color: #fff;
}

.muted {
  color: #999;
  font-size: 26rpx;
}

.title {
  font-size: 34rpx;
  font-weight: 600;
  color: #222;
  margin-bottom: 16rpx;
}
