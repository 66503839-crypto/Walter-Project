<view class="chat-wrap">
  <!-- 顶部：Provider 切换芯片 -->
  <scroll-view
    wx:if="{{providers.length > 0}}"
    class="provider-bar"
    scroll-x
    enable-flex
  >
    <view
      wx:for="{{providers}}"
      wx:key="id"
      class="chip {{currentProvider === item.id ? 'chip-active' : ''}}"
      data-id="{{item.id}}"
      bindtap="onSwitchProvider"
    >
      {{item.name}}
    </view>
  </scroll-view>

  <scroll-view
    class="chat-list"
    scroll-y
    scroll-into-view="{{scrollToId}}"
    scroll-with-animation
  >
    <view wx:if="{{messages.length === 0}}" class="empty muted">
      开始和 AI 聊点什么吧...
    </view>

    <view
      wx:for="{{messages}}"
      wx:key="id"
      id="{{item.id}}"
      class="msg msg-{{item.role}}"
    >
      <view class="bubble">{{item.content}}</view>
    </view>

    <view wx:if="{{sending}}" class="msg msg-assistant">
      <view class="bubble typing">AI 正在思考...</view>
    </view>
  </scroll-view>

  <view class="input-bar">
    <input
      class="input"
      placeholder="请输入..."
      value="{{input}}"
      bindinput="onInput"
      confirm-type="send"
      bindconfirm="onSend"
      disabled="{{sending}}"
    />
    <view class="btn-primary send-btn" bindtap="onSend">发送</view>
  </view>
</view>
