.chat-wrap {
  display: flex;
  flex-direction: column;
  height: 100vh;
}

/* 顶部 provider 切换条 */
.provider-bar {
  display: flex;
  white-space: nowrap;
  padding: 16rpx 20rpx;
  background: #fff;
  border-bottom: 2rpx solid #eee;
  flex-shrink: 0;
}
.chip {
  display: inline-block;
  padding: 12rpx 28rpx;
  margin-right: 16rpx;
  border-radius: 40rpx;
  font-size: 26rpx;
  background: #f0f2f5;
  color: #666;
  transition: all 0.15s;
}
.chip-active {
  background: #1296db;
  color: #fff;
  font-weight: 500;
}

.chat-list {
  flex: 1;
  padding: 24rpx;
  box-sizing: border-box;
}
.empty {
  text-align: center;
  padding: 200rpx 0;
}
.msg {
  display: flex;
  margin-bottom: 24rpx;
}
.msg-user {
  justify-content: flex-end;
}
.msg-assistant {
  justify-content: flex-start;
}
.bubble {
  max-width: 72%;
  padding: 20rpx 24rpx;
  border-radius: 16rpx;
  font-size: 30rpx;
  line-height: 1.5;
  word-wrap: break-word;
  white-space: pre-wrap;
}
.msg-user .bubble {
  background: #1296db;
  color: #fff;
  border-bottom-right-radius: 4rpx;
}
.msg-assistant .bubble {
  background: #fff;
  color: #222;
  border-bottom-left-radius: 4rpx;
}
.bubble.typing {
  color: #999;
  font-style: italic;
}

.input-bar {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 16rpx 24rpx;
  background: #fff;
  border-top: 2rpx solid #eee;
}
.input-bar .input {
  flex: 1;
  background: #f5f6f7;
  border-radius: 12rpx;
  padding: 20rpx;
  font-size: 30rpx;
}
.send-btn {
  padding: 20rpx 32rpx;
  flex-shrink: 0;
}
