.input-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}
.input {
  flex: 1;
  background: #f5f6f7;
  border-radius: 12rpx;
  padding: 20rpx;
  font-size: 30rpx;
}
.add-btn {
  padding: 20rpx 32rpx;
  flex-shrink: 0;
}

.empty {
  text-align: center;
  padding: 120rpx 0;
}

.todo {
  display: flex;
  align-items: center;
  gap: 24rpx;
}
.todo.done .todo-title {
  text-decoration: line-through;
  color: #999;
}
.checkbox {
  width: 44rpx;
  height: 44rpx;
  border: 2rpx solid #ccc;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 28rpx;
  flex-shrink: 0;
}
.checkbox.checked {
  background: #1296db;
  border-color: #1296db;
}
.todo-body {
  flex: 1;
  overflow: hidden;
}
.todo-title {
  font-size: 30rpx;
  color: #222;
}
.delete {
  width: 48rpx;
  height: 48rpx;
  text-align: center;
  line-height: 44rpx;
  font-size: 44rpx;
  color: #ccc;
}
