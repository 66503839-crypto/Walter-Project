{
  "compilerOptions": {
    "strict": true,
    "noImplicitAny": true,
    "noImplicitThis": true,
    "module": "CommonJS",
    "target": "ES2020",
    "moduleResolution": "Node",
    "experimentalDecorators": true,
    "noImplicitReturns": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "lib": ["ES2020"],
    "baseUrl": "./miniprogram",
    "paths": {
      "@/*": ["./*"]
    },
    "typeRoots": ["./typings", "./node_modules/@types"]
  },
  "include": [
    "./miniprogram/**/*.ts",
    "./typings/**/*.d.ts"
  ],
  "exclude": ["node_modules"]
}
