# 保证跨平台换行符一致，避免 Windows checkout 把 .sh 变成 CRLF
# 导致 Linux 上执行报 bad interpreter / shell syntax error

# 默认：文本文件让 Git 自动检测（签入统一 LF）
* text=auto eol=lf

# 明确：脚本 / 配置文件 必须是 LF
*.sh        text eol=lf
*.bash      text eol=lf
Dockerfile  text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.conf      text eol=lf
*.env       text eol=lf
.env.*      text eol=lf

# 明确：Windows 脚本用 CRLF
*.ps1       text eol=crlf
*.cmd       text eol=crlf
*.bat       text eol=crlf

# 二进制：不转换
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.webp      binary
*.ico       binary
*.pdf       binary
*.zip       binary
*.tar       binary
*.gz        binary
