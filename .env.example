# =================================================================
# MiniGamer 环境变量示例
# 复制为 server/.env 或 deploy/.env 后填入真实值
# 切勿提交到 Git！
# =================================================================

# ---------- 应用基础 ----------
APP_ENV=dev                       # dev | prod
APP_NAME=MiniGamer
APP_HOST=0.0.0.0
APP_PORT=8000
APP_DEBUG=true

# ---------- 数据库 ----------
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_USER=minigamer
POSTGRES_PASSWORD=change_me_in_prod
POSTGRES_DB=minigamer
# 完整 DSN（二选一）
DATABASE_URL=postgresql+asyncpg://minigamer:change_me_in_prod@127.0.0.1:5432/minigamer

# ---------- Redis ----------
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_URL=redis://127.0.0.1:6379/0

# ---------- JWT ----------
JWT_SECRET_KEY=please_generate_a_long_random_string_here_min_32_chars
JWT_ALGORITHM=HS256
JWT_ACCESS_TTL_MINUTES=60
JWT_REFRESH_TTL_DAYS=30

# ---------- 微信小程序 ----------
WECHAT_APPID=wx_replace_me
WECHAT_SECRET=replace_me
WECHAT_API_BASE=https://api.weixin.qq.com

# ---------- AI Provider ----------
# 可选值: openai | deepseek | qwen | mock
AI_PROVIDER=mock
AI_DEFAULT_MODEL=gpt-4o-mini

# OpenAI
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# DeepSeek（国内推荐，便宜）
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# 通义千问
QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# ---------- CORS ----------
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,https://servicewechat.com

# ---------- 日志 ----------
LOG_LEVEL=INFO
LOG_FILE=logs/app.log
